{
  "schemaVersion": 1,
  "id": "shield_rework",
  "version": "${version}",
  "name": "Shield Rework",
  "description": "Shields now have a health bar and can be broken by any item.",
  "authors": [
    "Rosenoire"
  ],
  "contact": {},
  "license": "All-Rights-Reserved",
  "icon": "assets/shield_rework/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "dev.rosenoire.shieldrework.client.ShieldReworkClient"
    ],
    "main": [
      "dev.rosenoire.shieldrework.common.ShieldRework"
    ],
    "cardinal-components-entity": [
      "dev.rosenoire.shieldrework.common.index.ModEntityComponents"
    ]
  },
  "mixins": [
